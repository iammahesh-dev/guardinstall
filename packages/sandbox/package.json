{
  "name": "@guardinstall/sandbox",
  "version": "1.1.0",
  "description": "Rust native addon for behavioral sandboxing using seccomp-BPF and Linux namespaces",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"process.platform==='win32'?process.exit(1):process.exit(0)\" && cargo build --release || cargo +stable-x86_64-pc-windows-gnu build --release",
    "build:win": "cargo +stable-x86_64-pc-windows-gnu build --release",
    "test": "cargo test"
  },
  "dependencies": {},
  "devDependencies": {},
  "keywords": [
    "security",
    "sandbox",
    "seccomp",
    "namespaces"
  ],
  "license": "MIT"
}
